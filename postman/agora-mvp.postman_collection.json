{
  "info": {
    "name": "Agora MVP",
    "description": "Collection para probar el backend MVP de Agora (provider-agnostic).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": ["{{base_url}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Ingest (Text)",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"text\": \"Cruzar la Alameda de noche se siente inseguro y faltan cruces claros.\",\n  \"place_code\": \"alameda-santiago\",\n  \"latitude\": -33.444,\n  \"longitude\": -70.66,\n  \"presence_mode\": \"walking\",\n  \"place_reference\": \"Alameda con Santa Rosa\"\n}"
        },
        "url": {"raw": "{{base_url}}/ingest", "host": ["{{base_url}}"], "path": ["ingest"]}
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('status is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "let jsonData = {};",
              "try { jsonData = pm.response.json(); } catch (e) {}",
              "if (jsonData.feedback_link) {",
              "  const parts = jsonData.feedback_link.split('/');",
              "  const token = parts[parts.length - 1];",
              "  pm.collectionVariables.set('feedback_token', token);",
              "}"
            ]
          }
        }
      ]
    },
    {
      "name": "Feedback View",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/feedback/{{feedback_token}}",
          "host": ["{{base_url}}"],
          "path": ["feedback", "{{feedback_token}}"]
        }
      }
    },
    {
      "name": "Feedback Patch",
      "request": {
        "method": "PATCH",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"primary_topic\": \"safety\",\n  \"desired_future\": \"safer_nights\",\n  \"summary_line\": \"Se percibe inseguridad nocturna y se piden cruces e iluminación mejores.\",\n  \"allow_public_quote\": false\n}"
        },
        "url": {
          "raw": "{{base_url}}/feedback/{{feedback_token}}",
          "host": ["{{base_url}}"],
          "path": ["feedback", "{{feedback_token}}"]
        }
      }
    },
    {
      "name": "WhatsApp Webhook (Generic)",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {"key": "Body", "value": "Desde WhatsApp: falta sombra para esperar en verano.", "type": "text"},
            {"key": "Latitude", "value": "-33.445", "type": "text"},
            {"key": "Longitude", "value": "-70.662", "type": "text"},
            {"key": "Address", "value": "Alameda con San Antonio", "type": "text"}
          ]
        },
        "url": {
          "raw": "{{base_url}}/integrations/whatsapp/webhook",
          "host": ["{{base_url}}"],
          "path": ["integrations", "whatsapp", "webhook"]
        }
      }
    },
    {
      "name": "WhatsApp Meta Verify (GET)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/integrations/whatsapp/meta/webhook?hub.mode=subscribe&hub.verify_token={{meta_verify_token}}&hub.challenge=12345",
          "host": ["{{base_url}}"],
          "path": ["integrations", "whatsapp", "meta", "webhook"],
          "query": [
            {"key": "hub.mode", "value": "subscribe"},
            {"key": "hub.verify_token", "value": "{{meta_verify_token}}"},
            {"key": "hub.challenge", "value": "12345"}
          ]
        }
      }
    },
    {
      "name": "WhatsApp Meta Webhook (POST)",
      "request": {
        "method": "POST",
        "header": [{"key": "Content-Type", "value": "application/json"}],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"object\": \"whatsapp_business_account\",\n  \"entry\": [\n    {\n      \"changes\": [\n        {\n          \"field\": \"messages\",\n          \"value\": {\n            \"messages\": [\n              {\n                \"type\": \"text\",\n                \"text\": {\n                  \"body\": \"Hola desde Meta Cloud API\"\n                }\n              }\n            ]\n          }\n        }\n      ]\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{base_url}}/integrations/whatsapp/meta/webhook",
          "host": ["{{base_url}}"],
          "path": ["integrations", "whatsapp", "meta", "webhook"]
        }
      }
    },
    {
      "name": "Twilio WhatsApp Webhook",
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "formdata",
          "formdata": [
            {"key": "Body", "value": "Twilio WhatsApp: cruces más seguros en Alameda.", "type": "text"},
            {"key": "From", "value": "whatsapp:+14155238886", "type": "text"},
            {"key": "WaId", "value": "56912345678", "type": "text"},
            {"key": "Latitude", "value": "-33.445", "type": "text"},
            {"key": "Longitude", "value": "-70.662", "type": "text"},
            {"key": "Address", "value": "Alameda con San Antonio", "type": "text"}
          ]
        },
        "url": {
          "raw": "{{base_url}}/integrations/whatsapp/twilio/webhook",
          "host": ["{{base_url}}"],
          "path": ["integrations", "whatsapp", "twilio", "webhook"]
        }
      }
    },
    {
      "name": "Admin Create Place",
      "request": {
        "method": "POST",
        "header": [
