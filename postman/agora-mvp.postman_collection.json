        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"code\": \"valparaiso-centro\",\n  \"name\": \"Centro de Valparaiso\",\n  \"city\": \"Valparaiso\",\n  \"country\": \"Chile\"\n}"
        },
        "url": {"raw": "{{base_url}}/admin/places", "host": ["{{base_url}}"], "path": ["admin", "places"]}
      }
    },
