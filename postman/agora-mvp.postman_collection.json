    {
      "name": "Run Cluster Job",
      "request": {
        "method": "POST",
        "header": [
          {"key": "Content-Type", "value": "application/json"},
          {"key": "X-Admin-Api-Key", "value": "{{admin_api_key}}"}
        ],
        "body": {"mode": "raw", "raw": "{\n  \"similarity_threshold\": 0.7,\n  \"min_cluster_size\": 2\n}"},
        "url": {"raw": "{{base_url}}/admin/jobs/cluster", "host": ["{{base_url}}"], "path": ["admin", "jobs", "cluster"]}
